---
---

<footer class="bg-primary-900 dark:bg-primary-950 text-white transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <!-- Conference Info -->
      <div class="md:col-span-4">
        <div class="flex items-center mb-4">
          <img class="h-12 w-auto mr-4" src="/images/logos/ipac27.png" alt="IPAC27 Logo" />
          <div>
            <h3 class="text-xl font-heading font-bold">IPAC'27</h3>
            <p class="text-primary-200">18th International Particle Accelerator Conference</p>
          </div>
        </div>
      </div>

      <!-- Sponsors -->
      <div class="md:col-span-3">
        <h4 class="text-lg font-semibold mb-4">Sponsored by</h4>
        <div class="flex items-center space-x-4">
          <img class="h-14 w-auto" src="/images/logos/sponsors/IEEE_NPSS_Logo_White.png" alt="IEEE-NPSS Logo" />
          <img class="h-14 w-auto" src="/images/logos/sponsors/APS_logo.svg" alt="APS Logo" />
        </div>
      </div>

      <!-- Host -->
      <div class="md:col-span-3">
        <h4 class="text-lg font-semibold mb-4">Hosted by</h4>
        <div class="flex items-center justify-start">
          <img class="h-24 w-auto" src="/images/logos/sponsors/FRIB_logo_white.png" alt="FRIB Logo" />
        </div>
      </div>

      <!-- Contact & Social -->
      <div class="md:col-span-2">
        
        <h4 class="text-lg font-semibold mb-4">Connect</h4>
        <ul class="space-y-2 text-primary-200">
          <li><a href="/contact" class="hover:text-white hover:underline transition-all duration-200">Contact Us</a></li>
          <li><a href="mailto:info@ipac27.org" class="hover:text-white hover:underline transition-all duration-200">info@ipac27.org</a></li>
        </ul>
        

      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-primary-700">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-primary-300 text-sm">
          © 2025 IPAC27. All rights reserved.
        </p>

      </div>
    </div>
  </div>
</footer>
