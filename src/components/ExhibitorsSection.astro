---
import type { Exhibitor } from '../data/exhibitors';
import { exhibitors, getExhibitorsByCategory } from '../data/exhibitors';

export interface ExhibitorsPageProps {
  showExhibitors?: boolean;
  featuredOnly?: boolean;
}

const { showExhibitors = true, featuredOnly = false } = Astro.props;

const displayExhibitors = featuredOnly 
  ? exhibitors.filter(e => e.featured)
  : exhibitors;

const categories = [...new Set(displayExhibitors.map(e => e.category))];
---

<div class="py-16 bg-primary-50 dark:bg-primary-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    {showExhibitors && (
      <section>
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-primary-900 dark:text-primary-100 mb-4">Exhibition & Industry Partners</h2>
          <p class="text-xl text-primary-600 dark:text-primary-300 max-w-3xl mx-auto">
            Discover cutting-edge products and services from leading companies in accelerator technology
          </p>
        </div>

        {categories.map((category) => {
          const categoryExhibitors = getExhibitorsByCategory(category);
          if (featuredOnly) {
            return categoryExhibitors.filter(e => e.featured);
          }
          return (
            categoryExhibitors.length > 0 && (
              <div class="mb-12">
                <h3 class="text-2xl font-semibold text-primary-900 dark:text-primary-100 mb-6">{category}</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                  {categoryExhibitors.map((exhibitor) => (
                    <div class="bg-white dark:bg-primary-800 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 overflow-hidden">
                      <div class="p-6">
                        <div class="flex items-center mb-4">
                          <img 
                            src={exhibitor.logo} 
                            alt={`${exhibitor.name} logo`}
                            class="h-12 w-auto object-contain mr-4"
                          />
                          <div>
                            <h4 class="text-lg font-semibold text-primary-900 dark:text-primary-100">{exhibitor.name}</h4>
                            {exhibitor.booth && (
                              <span class="text-sm text-primary-600 font-medium">Booth {exhibitor.booth}</span>
                            )}
                          </div>
                        </div>
                        <p class="text-primary-600 dark:text-primary-300 text-sm mb-4">{exhibitor.description}</p>
                        <div class="flex flex-wrap gap-2">
                          {exhibitor.website && (
                            <a href={exhibitor.website} target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center text-primary-600 hover:text-primary-700 text-sm font-medium">
                              Visit Website
                              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                              </svg>
                            </a>
                          )}
                          {exhibitor.featured && (
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-100 text-primary-800">
                              Featured
                            </span>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )
          );
        })}
      </section>
    )}
  </div>
</div>